        (function() {
          function applyLight() {
            document.documentElement.setAttribute('data-theme', 'light');
            document.documentElement.setAttribute('data-color-mode', 'light');
            document.documentElement.classList.remove('dark');
          }

          try {
            var pathname = window.location.pathname;
            var lightOnlyRoutes = ["/pricing","/careers","/terms-service","/privacy","/ccpa","/dpa","/comparison","/templates","/templates/categories","/built-with-rocket","/blog","/author","/launch-your-online-store","/launch-high-converting-landing-pages","/build-stunning-websites","/create-powerful-forms","/build-production-ready-mobile-apps","/remix","/turn-ideas-into-apps-that-work-your-way","/landing-pages","/checkout","/manage-subscription","/shared/artifact","/solve","/build","/intelligence","/see-it-in-action","/see-it-in-action/solve","/see-it-in-action/build","/see-it-in-action/intelligence","/rocket-vs-lovable","/vs-bolt","/vs-replit","/vs-v0","/vs-thunkable","/vs-lovable","/vs-emergent","/vs-base44","/vs-bubble","/author","/vs-framer","/vs-webflow","/vs-cursor","/intelligence/watchlist","/intelligence/watchlist/library","/intelligence/watchlist/:slug","/intelligence/watchlist/library/:slug","/intelligence/companies","/intelligence/companies/library","/intelligence/companies/:slug","/intelligence/companies/library/:slug","/ai-app-builder"];
            var isLightOnly = lightOnlyRoutes.some(function(route) {
              return pathname === route || pathname.indexOf(route + '/') === 0;
            });

            if (isLightOnly) {
              applyLight();
              return;
            }

            var stored = localStorage.getItem('theme');
            var theme = (stored === 'dark' || stored === 'light' || stored === 'system') ? stored : 'light';
            var isDark = theme === 'dark'
              ? true
              : theme === 'system'
                ? window.matchMedia('(prefers-color-scheme: dark)').matches
                : false;

            document.documentElement.setAttribute('data-theme', theme);
            document.documentElement.setAttribute('data-color-mode', isDark ? 'dark' : 'light');

            if (isDark) {
              document.documentElement.classList.add('dark');
            } else {
              document.documentElement.classList.remove('dark');
            }
          } catch (e) {
            applyLight();
          }
        })();
      </script><style>
